WEB_PORT=3001
API_PORT=8001
DB_PORT=5433
ADMINER_PORT=8080

OPENAI_API_KEY=
OPENAI_RAG_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (CheepChat uses Ollama when USE_OLLAMA_FOR_RAG=true)
# Use host.docker.internal when API runs in Docker and Ollama is on your machine
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=tinyllama
USE_OLLAMA_FOR_RAG=true

SEED_ON_STARTUP=true
